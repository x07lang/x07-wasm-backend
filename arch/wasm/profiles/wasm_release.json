{
  "schema_version": "x07.wasm.profile@0.2.0",
  "id": "wasm_release",
  "v": 1,

  "target": {
    "triple": "wasm32-wasi",
    "wasm_c_abi": "basic_c_abi@1",
    "entry_export": "x07_solve_v2"
  },

  "x07_build": {
    "freestanding": true,
    "emit_c_header": true
  },

  "clang": {
    "cflags": [
      "--target=wasm32-wasi",
      "-O3",
      "-DNDEBUG",
      "-std=c11",
      "-ffunction-sections",
      "-fdata-sections",
      "-fvisibility=hidden"
    ]
  },

  "wasm_ld": {
    "ldflags": [
      "--no-entry",
      "--stack-first",
      "-z",
      "stack-size=1048576",

      "--export=x07_solve_v2",
      "--export=__heap_base",
      "--export=__data_end",
      "--export-memory=memory",

      "--initial-memory=134217728",
      "--no-growable-memory",

      "--strip-debug",
      "--compress-relocations"
    ]
  },

  "defaults": {
    "arena_cap_bytes": 67108864,
    "max_output_bytes": 16777216
  },

  "runtime": {
    "max_fuel": null,
    "max_memory_bytes": null,
    "max_table_elements": null,
    "max_wasm_stack_bytes": 1048576
  }
}
