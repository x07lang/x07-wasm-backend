{
  "schema_version": "x07.device.capabilities@0.2.0",
  "network": {
    "mode": "deny_by_default",
    "allow_hosts": []
  },
  "device": {
    "camera": {
      "photo": false
    },
    "files": {
      "pick": true,
      "accept_defaults": ["image/*", "application/pdf"]
    },
    "blob_store": {
      "enabled": true,
      "max_total_bytes": 67108864,
      "max_item_bytes": 16777216
    },
    "location": {
      "foreground": false
    },
    "notifications": {
      "local": true,
      "push": false
    }
  }
}
