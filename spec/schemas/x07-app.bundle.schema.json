{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-app.bundle.schema.json",
  "title": "x07.app.bundle@0.1.0",
  "description": "Machine-readable manifest describing the built full-stack app bundle (frontend + backend).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "frontend",
    "backend"
  ],
  "properties": {
    "schema_version": { "const": "x07.app.bundle@0.1.0" },
    "profile_id": { "$ref": "#/$defs/id" },
    "frontend": { "$ref": "#/$defs/frontend" },
    "backend": { "$ref": "#/$defs/backend" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "rel_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?![\\\\/])(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": { "$ref": "#/$defs/rel_path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "dir_rel", "artifacts"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["core_wasm_v1", "component_jco_v1"]
        },
        "dir_rel": { "$ref": "#/$defs/rel_path" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": { "$ref": "#/$defs/file_digest" }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter", "artifact"],
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["wasi_http_proxy_v1"]
        },
        "artifact": { "$ref": "#/$defs/file_digest" }
      }
    }
  }
}
