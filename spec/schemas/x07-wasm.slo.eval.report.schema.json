{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.slo.eval.report.schema.json",
  "title": "x07.wasm.slo.eval.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm slo eval`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "ok", "exit_code", "diagnostics", "meta", "result"],
  "properties": {
    "schema_version": { "const": "x07.wasm.slo.eval.report@0.1.0" },
    "command": { "const": "x07-wasm.slo.eval" },
    "ok": { "type": "boolean" },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic" },
      "default": []
    },
    "meta": { "$ref": "#/$defs/meta" },
    "result": { "$ref": "#/$defs/result" }
  },
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "x07-wasm" },
        "version": { "type": "string" },
        "git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uses_os_time", "uses_network", "uses_process"],
      "properties": {
        "uses_os_time": { "type": "boolean" },
        "uses_network": { "type": "boolean" },
        "uses_process": { "type": "boolean" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "elapsed_ms", "cwd", "argv", "inputs", "outputs", "nondeterminism"],
      "properties": {
        "tool": { "$ref": "#/$defs/tool_meta" },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "cwd": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "nondeterminism": { "$ref": "#/$defs/nondeterminism" }
      }
    },
    "decision": {
      "type": "string",
      "enum": ["promote", "rollback", "inconclusive"]
    },
    "indicator_eval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "metric", "observed", "ok"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "kind": { "type": "string", "enum": ["error_rate", "latency_p95_ms", "availability"] },
        "metric": { "type": "string", "minLength": 1, "maxLength": 128 },
        "observed": { "type": "number" },
        "ok": { "type": "boolean" },
        "objective": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "max_ms": { "type": "integer", "minimum": 0 }
          },
          "default": {}
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slo_profile", "metrics_snapshot", "decision", "violations", "indicators"],
      "properties": {
        "slo_profile": { "$ref": "#/$defs/file_digest" },
        "metrics_snapshot": { "$ref": "#/$defs/file_digest" },
        "decision": { "$ref": "#/$defs/decision" },
        "violations": { "type": "integer", "minimum": 0 },
        "indicators": { "type": "array", "items": { "$ref": "#/$defs/indicator_eval" }, "default": [] }
      }
    }
  }
}
