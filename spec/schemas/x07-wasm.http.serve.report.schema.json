{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.http.serve.report.schema.json",
  "title": "x07.wasm.http.serve.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm http serve`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "properties": {
    "schema_version": {
      "const": "x07.wasm.http.serve.report@0.1.0"
    },
    "command": {
      "const": "x07-wasm.http.serve"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic"
      },
      "default": []
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "result": {
      "$ref": "#/$defs/result"
    }
  },
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "x07-wasm"
        },
        "version": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$"
        },
        "rustc": {
          "type": "string"
        },
        "wasmtime": {
          "type": "string"
        }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes_len": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uses_os_time",
        "uses_network",
        "uses_process"
      ],
      "properties": {
        "uses_os_time": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_process": {
          "type": "boolean"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "elapsed_ms",
        "cwd",
        "argv",
        "inputs",
        "outputs",
        "nondeterminism"
      ],
      "properties": {
        "tool": {
          "$ref": "#/$defs/tool_meta"
        },
        "elapsed_ms": {
          "type": "integer",
          "minimum": 0
        },
        "cwd": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "nondeterminism": {
          "$ref": "#/$defs/nondeterminism"
        }
      }
    },
    "response_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "headers_count",
        "body_bytes"
      ],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "headers_count": {
          "type": "integer",
          "minimum": 0
        },
        "body_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "component",
        "runtime_limits",
        "requests",
        "responses",
        "trace_path",
        "incident_dir"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "canary",
            "listen"
          ]
        },
        "component": {
          "$ref": "#/$defs/file_digest"
        },
        "runtime_limits": {
          "$ref": "https://x07.io/spec/x07-wasm.runtime.limits.schema.json"
        },
        "requests": {
          "type": "integer",
          "minimum": 0
        },
        "responses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/response_summary"
          },
          "default": []
        },
        "trace_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "incident_dir": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    }
  }
}
