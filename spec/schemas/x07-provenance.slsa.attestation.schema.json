{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-provenance.slsa.attestation.schema.json",
  "title": "x07.provenance.slsa.attestation@0.1.0",
  "description": "SLSA provenance attestation (in-toto Statement v1, predicateType https://slsa.dev/provenance/v1) with minimal required fields for x07 packs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/subject" }
    },
    "predicateType": {
      "type": "string",
      "const": "https://slsa.dev/provenance/v1"
    },
    "predicate": {
      "$ref": "#/$defs/predicate"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "digest_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256"],
      "properties": {
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "digest"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "digest": { "$ref": "#/$defs/digest_set" },
        "mediaType": { "type": "string", "maxLength": 256 }
      }
    },
    "resource_descriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri", "digest"],
      "properties": {
        "uri": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "digest": { "$ref": "#/$defs/digest_set" }
      }
    },
    "builder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "build_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buildType", "externalParameters", "internalParameters", "resolvedDependencies"],
      "properties": {
        "buildType": { "type": "string", "minLength": 1, "maxLength": 512 },
        "externalParameters": { "type": "object", "additionalProperties": true, "default": {} },
        "internalParameters": { "type": "object", "additionalProperties": true, "default": {} },
        "resolvedDependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/resource_descriptor" },
          "default": []
        }
      }
    },
    "run_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startedOn", "finishedOn"],
      "properties": {
        "startedOn": { "type": "string", "format": "date-time" },
        "finishedOn": { "type": "string", "format": "date-time" },
        "invocationId": { "type": "string", "maxLength": 1024 }
      }
    },
    "run_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["builder", "metadata"],
      "properties": {
        "builder": { "$ref": "#/$defs/builder" },
        "metadata": { "$ref": "#/$defs/run_metadata" }
      }
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buildDefinition", "runDetails"],
      "properties": {
        "buildDefinition": { "$ref": "#/$defs/build_definition" },
        "runDetails": { "$ref": "#/$defs/run_details" },
        "x07": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pack_manifest_sha256": { "$ref": "#/$defs/sha256" },
            "ops_profile_sha256": { "$ref": "#/$defs/sha256" },
            "capabilities_sha256": { "$ref": "#/$defs/sha256" },
            "slo_profile_sha256": { "$ref": "#/$defs/sha256" }
          },
          "default": {}
        }
      }
    }
  }
}
