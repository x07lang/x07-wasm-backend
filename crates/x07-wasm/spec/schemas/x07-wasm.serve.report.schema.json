{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.serve.report.schema.json",
  "title": "x07.wasm.serve.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm serve`.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.wasm.serve.report@0.1.0"
    },
    "command": {
      "type": "string",
      "const": "x07-wasm.serve"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic"
      },
      "default": []
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "result": {
      "$ref": "#/$defs/result"
    }
  },
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "u32": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "u64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "x07-wasm"
        },
        "version": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$"
        },
        "rustc": {
          "type": "string"
        },
        "clang": {
          "type": "string"
        },
        "wasm_ld": {
          "type": "string"
        },
        "wasmtime": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ]
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes_len": {
          "$ref": "#/$defs/u64"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ]
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uses_os_time": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_process": {
          "type": "boolean"
        }
      },
      "required": [
        "uses_os_time",
        "uses_network",
        "uses_process"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "$ref": "#/$defs/tool_meta"
        },
        "elapsed_ms": {
          "$ref": "#/$defs/u64"
        },
        "cwd": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "nondeterminism": {
          "$ref": "#/$defs/nondeterminism"
        }
      },
      "required": [
        "tool",
        "elapsed_ms",
        "cwd",
        "argv",
        "inputs",
        "outputs",
        "nondeterminism"
      ]
    },
    "blob_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes_len"
      ],
      "description": "Reference to a binary blob. Provide either {path,sha256} or {base64}. sha256 is strongly recommended.",
      "properties": {
        "bytes_len": {
          "$ref": "#/$defs/u64"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "base64": {
          "type": "string"
        }
      }
    },
    "serve_addr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requested": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "bound": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "requested",
        "bound"
      ]
    },
    "serve_budgets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_request_bytes": {
          "$ref": "#/$defs/u64"
        },
        "max_response_bytes": {
          "$ref": "#/$defs/u64"
        },
        "max_wall_ms_per_request": {
          "$ref": "#/$defs/u64"
        },
        "max_concurrent": {
          "$ref": "#/$defs/u32"
        }
      },
      "required": [
        "max_request_bytes",
        "max_response_bytes",
        "max_wall_ms_per_request",
        "max_concurrent"
      ]
    },
    "response_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "status": {
          "type": "integer",
          "minimum": 0,
          "maximum": 999
        },
        "body": {
          "$ref": "#/$defs/blob_ref"
        },
        "wall_ms": {
          "$ref": "#/$defs/u64"
        }
      },
      "required": [
        "ok",
        "status",
        "body",
        "wall_ms"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "canary",
            "listen"
          ]
        },
        "component": {
          "$ref": "#/$defs/file_digest"
        },
        "addr": {
          "$ref": "#/$defs/serve_addr"
        },
        "stop_after": {
          "$ref": "#/$defs/u32"
        },
        "budgets": {
          "$ref": "#/$defs/serve_budgets"
        },
        "responses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/response_summary"
          },
          "default": []
        },
        "incidents": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "default": []
        }
      },
      "required": [
        "mode",
        "component",
        "addr",
        "stop_after",
        "budgets",
        "responses",
        "incidents"
      ]
    }
  }
}
