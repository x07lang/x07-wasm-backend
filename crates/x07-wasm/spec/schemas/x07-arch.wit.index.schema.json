{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-arch.wit.index.schema.json",
  "title": "x07.arch.wit.index@0.1.0",
  "description": "Pinned WIT package registry for offline component builds and validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packages"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.arch.wit.index@0.1.0"
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/package"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "rel_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?![\\\\/])(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "semver": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([+-][0-9A-Za-z.-]+)?$"
    },
    "wit_package_id": {
      "type": "string",
      "minLength": 5,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9_-]{0,31}:[a-z][a-z0-9_-]{0,63}@[0-9]+\\.[0-9]+\\.[0-9]+([+-][0-9A-Za-z.-]+)?$",
      "description": "WIT package id: namespace:package@semver (e.g., wasi:http@0.2.8)."
    },
    "package_kind": {
      "type": "string",
      "enum": [
        "local",
        "vendored"
      ]
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/wit_package_id"
        },
        "path": {
          "$ref": "#/$defs/rel_path"
        },
        "kind": {
          "$ref": "#/$defs/package_kind"
        },
        "sha256_tree": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}

