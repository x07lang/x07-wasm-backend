{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.device.verify.report.schema.json",
  "title": "x07.wasm.device.verify.report@0.2.0",
  "description": "Machine-readable report emitted by `x07-wasm device verify`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "ok", "exit_code", "diagnostics", "meta", "result"],
  "properties": {
    "schema_version": { "const": "x07.wasm.device.verify.report@0.2.0" },
    "command": { "const": "x07-wasm.device.verify" },
    "ok": { "type": "boolean" },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic" },
      "default": []
    },
    "meta": { "$ref": "#/$defs/meta" },
    "result": { "$ref": "#/$defs/result" }
  },
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "x07-wasm" },
        "version": { "type": "string" },
        "git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" },
        "rustc": { "type": "string" },
        "clang": { "type": "string" },
        "wasm_ld": { "type": "string" },
        "wasmtime": { "type": "string" }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uses_os_time", "uses_network", "uses_process"],
      "properties": {
        "uses_os_time": { "type": "boolean" },
        "uses_network": { "type": "boolean" },
        "uses_process": { "type": "boolean" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "elapsed_ms", "cwd", "argv", "inputs", "outputs", "nondeterminism"],
      "properties": {
        "tool": { "$ref": "#/$defs/tool_meta" },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "cwd": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "nondeterminism": { "$ref": "#/$defs/nondeterminism" }
      }
    },
    "readiness_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "field"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Z][A-Z0-9_]+$" },
        "message": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "field": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 512 },
            { "type": "null" }
          ]
        }
      }
    },
    "release_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "warnings", "errors"],
      "properties": {
        "status": { "type": "string", "enum": ["ok", "warning", "error"] },
        "warnings": { "type": "array", "items": { "$ref": "#/$defs/readiness_issue" }, "default": [] },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/readiness_issue" }, "default": [] }
      }
    },
    "blob_store_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "max_total_bytes", "max_item_bytes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "max_total_bytes": { "type": "integer", "minimum": 0 },
        "max_item_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "capabilities_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "camera_photo",
        "files_pick",
        "files_accept_defaults",
        "blob_store",
        "location_foreground",
        "notifications_local",
        "notifications_push",
        "network_allow_hosts"
      ],
      "properties": {
        "camera_photo": { "type": "boolean" },
        "files_pick": { "type": "boolean" },
        "files_accept_defaults": { "type": "array", "items": { "type": "string" }, "default": [] },
        "blob_store": { "$ref": "#/$defs/blob_store_summary" },
        "location_foreground": { "type": "boolean" },
        "notifications_local": { "type": "boolean" },
        "notifications_push": { "type": "boolean" },
        "network_allow_hosts": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "native_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_kind",
        "provider_kind",
        "bundle_manifest_sha256",
        "package_manifest_sha256",
        "capabilities",
        "permission_declarations",
        "telemetry_classes"
      ],
      "properties": {
        "target_kind": { "type": "string", "enum": ["desktop", "ios", "android"] },
        "provider_kind": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 128 },
            { "type": "null" }
          ]
        },
        "bundle_manifest_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        },
        "package_manifest_sha256": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            { "type": "null" }
          ]
        },
        "capabilities": { "$ref": "#/$defs/capabilities_summary" },
        "permission_declarations": { "type": "array", "items": { "type": "string" }, "default": [] },
        "telemetry_classes": { "type": "array", "items": { "type": "string" }, "default": [] }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_dir",
        "bundle_manifest",
        "files_checked",
        "missing_files",
        "digest_mismatches",
        "bundle_digest_ok",
        "host_abi_hash_ok",
        "native_summary",
        "release_readiness"
      ],
      "properties": {
        "bundle_dir": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "bundle_manifest": { "$ref": "#/$defs/file_digest" },
        "files_checked": { "type": "integer", "minimum": 0 },
        "missing_files": { "type": "integer", "minimum": 0 },
        "digest_mismatches": { "type": "integer", "minimum": 0 },
        "bundle_digest_ok": { "type": "boolean" },
        "host_abi_hash_ok": { "type": "boolean" },
        "native_summary": {
          "oneOf": [
            { "$ref": "#/$defs/native_summary" },
            { "type": "null" }
          ]
        },
        "release_readiness": {
          "oneOf": [
            { "$ref": "#/$defs/release_readiness" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
