{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-slo.profile.schema.json",
  "title": "x07.slo.profile@0.1.0",
  "description": "SLO profile (JSON-native) for offline evaluation and promotion/rollback decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "v", "service", "indicators"],
  "properties": {
    "schema_version": { "const": "x07.slo.profile@0.1.0" },
    "id": { "$ref": "#/$defs/id" },
    "v": { "type": "integer", "minimum": 1 },
    "service": { "type": "string", "minLength": 1, "maxLength": 256 },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": { "$ref": "#/$defs/indicator" }
    },
    "notes": { "type": "string", "maxLength": 16384 }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "metric_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "kind": {
      "type": "string",
      "enum": ["error_rate", "latency_p95_ms", "availability"]
    },
    "ratio": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "objective_error_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max"],
      "properties": { "max": { "$ref": "#/$defs/ratio" } }
    },
    "objective_availability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min"],
      "properties": { "min": { "$ref": "#/$defs/ratio" } }
    },
    "objective_latency_p95_ms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_ms"],
      "properties": { "max_ms": { "type": "integer", "minimum": 0 } }
    },
    "indicator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "metric", "window_s", "objective"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "$ref": "#/$defs/kind" },
        "metric": { "$ref": "#/$defs/metric_name" },
        "window_s": { "type": "integer", "minimum": 1, "maximum": 31536000 },
        "objective": {}
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "error_rate" } }, "required": ["kind"] },
          "then": { "properties": { "objective": { "$ref": "#/$defs/objective_error_rate" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "availability" } }, "required": ["kind"] },
          "then": { "properties": { "objective": { "$ref": "#/$defs/objective_availability" } } }
        },
        {
          "if": { "properties": { "kind": { "const": "latency_p95_ms" } }, "required": ["kind"] },
          "then": { "properties": { "objective": { "$ref": "#/$defs/objective_latency_p95_ms" } } }
        }
      ]
    }
  }
}
