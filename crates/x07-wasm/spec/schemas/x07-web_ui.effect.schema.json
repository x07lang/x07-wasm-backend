{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-web_ui.effect.schema.json",
  "title": "x07.web_ui.effect@0.2.0",
  "description": "Typed effect surface for x07 web-ui reducers, including the M0 native device request families.",
  "oneOf": [
    { "$ref": "#/$defs/http_request" },
    { "$ref": "#/$defs/storage_get" },
    { "$ref": "#/$defs/storage_set" },
    { "$ref": "#/$defs/nav_push" },
    { "$ref": "#/$defs/nav_replace" },
    { "$ref": "#/$defs/timer_set" },
    { "$ref": "#/$defs/timer_clear" },
    { "$ref": "#/$defs/device_permissions_query" },
    { "$ref": "#/$defs/device_permissions_request" },
    { "$ref": "#/$defs/device_camera_capture" },
    { "$ref": "#/$defs/device_clipboard_copy_text" },
    { "$ref": "#/$defs/device_clipboard_read_text" },
    { "$ref": "#/$defs/device_files_pick" },
    { "$ref": "#/$defs/device_files_save_json" },
    { "$ref": "#/$defs/device_files_save_text" },
    { "$ref": "#/$defs/device_blobs_stat" },
    { "$ref": "#/$defs/device_blobs_delete" },
    { "$ref": "#/$defs/device_location_get_current" },
    { "$ref": "#/$defs/device_notifications_schedule" },
    { "$ref": "#/$defs/device_notifications_cancel" },
    { "$ref": "#/$defs/device_share_share_files" },
    { "$ref": "#/$defs/device_share_share_text" }
  ],
  "$defs": {
    "v1": { "type": "integer", "const": 1 },
    "json_string": { "type": "string" },
    "json_value": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        { "type": "array", "items": { "$ref": "#/$defs/json_value" } },
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/json_value" } }
      ]
    },
    "delay_ms": { "type": "integer", "minimum": 0 },
    "bool": { "type": "boolean" },
    "device_effect_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "request_id", "op", "capability", "payload"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string" },
        "request_id": { "$ref": "#/$defs/json_string" },
        "op": { "type": "string" },
        "capability": { "$ref": "#/$defs/json_string" },
        "payload": { "type": "object" }
      }
    },
    "http_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "request"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.http.request" },
        "request": { "$ref": "https://x07.io/spec/x07-http.request.envelope.schema.json" }
      }
    },
    "storage_get": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "key"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.storage.get" },
        "key": { "$ref": "#/$defs/json_string" }
      }
    },
    "storage_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "key", "value"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.storage.set" },
        "key": { "$ref": "#/$defs/json_string" },
        "value": { "$ref": "#/$defs/json_string" }
      }
    },
    "nav_push": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "path"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.nav.push" },
        "path": { "$ref": "#/$defs/json_string" }
      }
    },
    "nav_replace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "path"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.nav.replace" },
        "path": { "$ref": "#/$defs/json_string" }
      }
    },
    "timer_set": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "id", "delay_ms"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.timer.set" },
        "id": { "$ref": "#/$defs/json_string" },
        "delay_ms": { "$ref": "#/$defs/delay_ms" }
      }
    },
    "timer_clear": {
      "type": "object",
      "additionalProperties": false,
      "required": ["v", "kind", "id"],
      "properties": {
        "v": { "$ref": "#/$defs/v1" },
        "kind": { "type": "string", "const": "x07.web_ui.effect.timer.clear" },
        "id": { "$ref": "#/$defs/json_string" }
      }
    },
    "device_permissions_query": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.permissions.query" },
            "op": { "const": "permissions.query" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["permission"],
              "properties": {
                "permission": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_permissions_request": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.permissions.request" },
            "op": { "const": "permissions.request" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["permission"],
              "properties": {
                "permission": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_camera_capture": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.camera.capture" },
            "op": { "const": "camera.capture" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "quality": { "$ref": "#/$defs/json_string" },
                "lens": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_clipboard_copy_text": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.clipboard.copy_text" },
            "op": { "const": "clipboard.write_text" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["text"],
              "properties": {
                "text": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_clipboard_read_text": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.clipboard.read_text" },
            "op": { "const": "clipboard.read_text" },
            "payload": {
              "type": "object",
              "additionalProperties": false
            }
          }
        }
      ]
    },
    "device_files_pick": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.files.pick" },
            "op": { "const": "files.pick" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["accept", "multiple"],
              "properties": {
                "accept": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/json_string" }
                },
                "multiple": { "$ref": "#/$defs/bool" }
              }
            }
          }
        }
      ]
    },
    "device_files_save_json": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.files.save_json" },
            "op": { "const": "files.save" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "value"],
              "properties": {
                "name": { "$ref": "#/$defs/json_string" },
                "value": { "$ref": "#/$defs/json_value" }
              }
            }
          }
        }
      ]
    },
    "device_files_save_text": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.files.save_text" },
            "op": { "const": "files.save" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "text"],
              "properties": {
                "name": { "$ref": "#/$defs/json_string" },
                "text": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_blobs_stat": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.blobs.stat" },
            "op": { "const": "blobs.stat" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["handle"],
              "properties": {
                "handle": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_blobs_delete": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.blobs.delete" },
            "op": { "const": "blobs.delete" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["handle"],
              "properties": {
                "handle": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_location_get_current": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.location.get_current" },
            "op": { "const": "location.get_current" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "timeout_ms": { "$ref": "#/$defs/delay_ms" }
              }
            }
          }
        }
      ]
    },
    "device_notifications_schedule": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.notifications.schedule" },
            "op": { "const": "notifications.schedule" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["notification_id", "title", "body", "delay_ms"],
              "properties": {
                "notification_id": { "$ref": "#/$defs/json_string" },
                "title": { "$ref": "#/$defs/json_string" },
                "body": { "$ref": "#/$defs/json_string" },
                "delay_ms": { "$ref": "#/$defs/delay_ms" }
              }
            }
          }
        }
      ]
    },
    "device_notifications_cancel": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.notifications.cancel" },
            "op": { "const": "notifications.cancel" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["notification_id"],
              "properties": {
                "notification_id": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_share_share_files": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.share.share_files" },
            "op": { "const": "share.present" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "title": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    },
    "device_share_share_text": {
      "allOf": [
        { "$ref": "#/$defs/device_effect_base" },
        {
          "properties": {
            "kind": { "const": "x07.web_ui.effect.device.share.share_text" },
            "op": { "const": "share.present" },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["text"],
              "properties": {
                "title": { "$ref": "#/$defs/json_string" },
                "text": { "$ref": "#/$defs/json_string" },
                "url": { "$ref": "#/$defs/json_string" }
              }
            }
          }
        }
      ]
    }
  }
}
