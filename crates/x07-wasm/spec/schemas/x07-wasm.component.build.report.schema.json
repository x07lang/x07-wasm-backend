{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.component.build.report.schema.json",
  "title": "x07.wasm.component.build.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm component build` (Phase 1 + Phase 4B).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.wasm.component.build.report@0.1.0"
    },
    "command": {
      "type": "string",
      "const": "x07-wasm.component.build"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic"
      },
      "default": []
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "result": {
      "$ref": "#/$defs/result"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "u64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "x07-wasm"
        },
        "version": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$"
        },
        "rustc": {
          "type": "string"
        },
        "clang": {
          "type": "string"
        },
        "wasm_ld": {
          "type": "string"
        },
        "wasmtime": {
          "type": "string"
        }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes_len": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uses_os_time",
        "uses_network",
        "uses_process"
      ],
      "properties": {
        "uses_os_time": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_process": {
          "type": "boolean"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "elapsed_ms",
        "cwd",
        "argv",
        "inputs",
        "outputs",
        "nondeterminism"
      ],
      "properties": {
        "tool": {
          "$ref": "#/$defs/tool_meta"
        },
        "elapsed_ms": {
          "$ref": "#/$defs/u64"
        },
        "cwd": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "nondeterminism": {
          "$ref": "#/$defs/nondeterminism"
        }
      }
    },
    "ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "v"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "v": {
          "$ref": "#/$defs/u64"
        }
      }
    },
    "file_digest_or_null": {
      "anyOf": [
        {
          "$ref": "#/$defs/file_digest"
        },
        {
          "type": "null"
        }
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emit",
        "project",
        "out_dir",
        "component_profile",
        "wasm_profile",
        "solve_core_wasm",
        "artifacts"
      ],
      "properties": {
        "emit": {
          "type": "string",
          "enum": [
            "solve",
            "http",
            "http-state-doc",
            "cli",
            "http-native",
            "cli-native",
            "http-adapter",
            "cli-adapter",
            "all"
          ]
        },
        "project": {
          "$ref": "#/$defs/file_digest"
        },
        "out_dir": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "component_profile": {
          "$ref": "#/$defs/ref"
        },
        "wasm_profile": {
          "$ref": "#/$defs/ref"
        },
        "solve_core_wasm": {
          "$ref": "#/$defs/file_digest_or_null"
        },
        "artifacts": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "https://x07.io/spec/x07-wasm.component.artifact.schema.json"
          },
          "default": []
        }
      }
    }
  }
}
