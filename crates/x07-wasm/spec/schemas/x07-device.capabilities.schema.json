{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-device.capabilities.schema.json",
  "title": "x07.device.capabilities@0.2.0",
  "description": "Pinned strict-M0 device runtime capability allowlist consumed by x07-wasm device tooling and device hosts, including the Forge builder-I/O clipboard, file, drop, share, audio, and haptics capabilities.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "network", "device"],
  "properties": {
    "schema_version": { "const": "x07.device.capabilities@0.2.0" },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allow_hosts"],
      "properties": {
        "mode": { "const": "deny_by_default" },
        "allow_hosts": {
          "type": "array",
          "minItems": 0,
          "maxItems": 64,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9.-]*[A-Za-z0-9]$|^localhost$|^127\\.0\\.0\\.1$"
          },
          "uniqueItems": true
        }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["camera", "files", "blob_store", "location", "notifications"],
      "properties": {
        "camera": {
          "type": "object",
          "additionalProperties": false,
          "required": ["photo"],
          "properties": {
            "photo": { "type": "boolean" }
          }
        },
        "audio": {
          "type": "object",
          "additionalProperties": false,
          "required": ["playback"],
          "properties": {
            "playback": { "type": "boolean" }
          }
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pick", "accept_defaults"],
          "properties": {
            "pick": { "type": "boolean" },
            "pick_multiple": { "type": "boolean" },
            "save": { "type": "boolean" },
            "drop": { "type": "boolean" },
            "accept_defaults": {
              "type": "array",
              "minItems": 0,
              "maxItems": 16,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "uniqueItems": true
            }
          }
        },
        "clipboard": {
          "type": "object",
          "additionalProperties": false,
          "required": ["read_text", "write_text"],
          "properties": {
            "read_text": { "type": "boolean" },
            "write_text": { "type": "boolean" }
          }
        },
        "blob_store": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "max_total_bytes", "max_item_bytes"],
          "properties": {
            "enabled": { "type": "boolean" },
            "max_total_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
            "max_item_bytes": { "type": "integer", "minimum": 1, "maximum": 268435456 }
          }
        },
        "haptics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" }
          }
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["foreground"],
          "properties": {
            "foreground": { "type": "boolean" }
          }
        },
        "notifications": {
          "type": "object",
          "additionalProperties": false,
          "required": ["local", "push"],
          "properties": {
            "local": { "type": "boolean" },
            "push": { "type": "boolean" }
          }
        },
        "share": {
          "type": "object",
          "additionalProperties": false,
          "required": ["present"],
          "properties": {
            "present": { "type": "boolean" }
          }
        }
      }
    }
  }
}
