{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.build.report.schema.json",
  "title": "x07.wasm.build.report@0.2.0",
  "description": "Machine-readable report emitted by `x07-wasm build` (x07 -> wasm32).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.wasm.build.report@0.2.0"
    },
    "command": {
      "type": "string",
      "const": "x07-wasm.build"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic"
      },
      "default": []
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "result": {
      "$ref": "#/$defs/result"
    }
  },
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "x07-wasm"
        },
        "version": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$"
        },
        "rustc": {
          "type": "string"
        },
        "clang": {
          "type": "string"
        },
        "wasm_ld": {
          "type": "string"
        },
        "wasmtime": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ]
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes_len": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ]
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uses_os_time": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_process": {
          "type": "boolean"
        }
      },
      "required": [
        "uses_os_time",
        "uses_network",
        "uses_process"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "$ref": "#/$defs/tool_meta"
        },
        "elapsed_ms": {
          "type": "integer",
          "minimum": 0
        },
        "cwd": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "nondeterminism": {
          "$ref": "#/$defs/nondeterminism"
        }
      },
      "required": [
        "tool",
        "elapsed_ms",
        "cwd",
        "argv",
        "inputs",
        "outputs",
        "nondeterminism"
      ]
    },
    "profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "v": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": [
        "id",
        "v"
      ]
    },
    "memory_plan": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stack_first": {
          "type": "boolean"
        },
        "stack_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "initial_memory_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "max_memory_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "growable_memory": {
          "type": "boolean"
        }
      },
      "required": [
        "stack_first",
        "stack_size_bytes",
        "initial_memory_bytes",
        "max_memory_bytes",
        "growable_memory"
      ]
    },
    "exports_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "found",
        "missing"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "found": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "missing": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "emit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emit_dir",
        "c_path",
        "h_path"
      ],
      "properties": {
        "emit_dir": {
          "type": "string"
        },
        "c_path": {
          "type": "string"
        },
        "h_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      }
    },
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "codegen_backend"
      ],
      "properties": {
        "codegen_backend": {
          "type": "string",
          "enum": [
            "c_toolchain_v1",
            "native_x07_wasm_v1"
          ]
        },
        "clang": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "wasm_ld": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "emit",
        "wasm",
        "artifact",
        "exports",
        "memory",
        "flags"
      ],
      "properties": {
        "profile": {
          "$ref": "#/$defs/profile_ref"
        },
        "emit": {
          "$ref": "#/$defs/emit"
        },
        "wasm": {
          "$ref": "#/$defs/file_digest"
        },
        "artifact": {
          "$ref": "https://x07.io/spec/x07-wasm.artifact.schema.json"
        },
        "exports": {
          "$ref": "#/$defs/exports_check"
        },
        "memory": {
          "$ref": "#/$defs/memory_plan"
        },
        "flags": {
          "$ref": "#/$defs/flags"
        }
      }
    }
  }
}
