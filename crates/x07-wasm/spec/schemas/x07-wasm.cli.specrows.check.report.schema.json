{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.cli.specrows.check.report.schema.json",
  "title": "x07.wasm.cli.specrows.check.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm cli specrows check` (validates x07cli.specrows@0.1.0).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.wasm.cli.specrows.check.report@0.1.0"
    },
    "command": {
      "type": "string",
      "const": "x07-wasm.cli.specrows.check"
    },
    "ok": { "type": "boolean" },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic" },
      "default": []
    },
    "meta": { "$ref": "#/$defs/meta" },
    "result": { "$ref": "#/$defs/result" }
  },
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "x07-wasm" },
        "version": { "type": "string" },
        "git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" },
        "rustc": { "type": "string" }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uses_os_time", "uses_network", "uses_process"],
      "properties": {
        "uses_os_time": { "type": "boolean" },
        "uses_network": { "type": "boolean" },
        "uses_process": { "type": "boolean" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "elapsed_ms", "cwd", "argv", "inputs", "outputs", "nondeterminism"],
      "properties": {
        "tool": { "$ref": "#/$defs/tool_meta" },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "cwd": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "nondeterminism": { "$ref": "#/$defs/nondeterminism" }
      }
    },
    "scope": {
      "type": "string",
      "pattern": "^(root|[a-z][a-z0-9_-]{0,31})$"
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "parsed_ok",
        "schema_id",
        "schema_valid",
        "rows_count",
        "scopes",
        "invariants"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["self_v1", "stdin_v1", "file_v1"]
        },
        "input": {
          "anyOf": [
            { "$ref": "#/$defs/file_digest" },
            { "type": "null" }
          ],
          "default": null
        },
        "parsed_ok": { "type": "boolean" },
        "schema_id": {
          "type": "string",
          "const": "https://x07.org/spec/x07cli.specrows.schema.json"
        },
        "schema_valid": { "type": "boolean" },
        "rows_count": { "type": "integer", "minimum": 0 },
        "scopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/scope" },
          "default": []
        },
        "invariants": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "expect_app_name",
            "app_name",
            "app_version",
            "has_root_help",
            "has_root_version",
            "has_root_cli_specrows",
            "ordering_checked",
            "ordering_ok"
          ],
          "properties": {
            "expect_app_name": { "type": "string" },
            "app_name": { "type": ["string", "null"], "default": null },
            "app_version": { "type": ["string", "null"], "default": null },
            "has_root_help": { "type": "boolean" },
            "has_root_version": { "type": "boolean" },
            "has_root_cli_specrows": { "type": "boolean" },
            "ordering_checked": { "type": "boolean" },
            "ordering_ok": { "type": "boolean" }
          }
        }
      }
    }
  }
}
