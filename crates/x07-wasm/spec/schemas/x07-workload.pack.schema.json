{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-workload.pack.schema.json",
  "title": "x07.workload.pack@0.1.0",
  "description": "Deployable workload pack manifest for service-oriented x07 backends.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workload_id",
    "public_manifest",
    "workload",
    "binding_requirements",
    "topology",
    "sources",
    "cells"
  ],
  "properties": {
    "schema_version": {
      "const": "x07.workload.pack@0.1.0"
    },
    "workload_id": {
      "$ref": "#/$defs/id"
    },
    "public_manifest": {
      "$ref": "#/$defs/file_digest"
    },
    "workload": {
      "$ref": "#/$defs/file_digest"
    },
    "binding_requirements": {
      "$ref": "#/$defs/file_digest"
    },
    "topology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file_digest"
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/file_digest"
      }
    },
    "performance_hints": {
      "oneOf": [
        {
          "$ref": "#/$defs/performance_hints"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "slo_spec": {
      "oneOf": [
        {
          "$ref": "#/$defs/slo_spec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cell_runtime"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "rel_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?![\\\\/])(?![A-Za-z]:)(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "ratio": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/rel_path"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes_len": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "performance_hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "expected_p95_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "memory_class": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "io_profile": {
          "type": "string",
          "enum": [
            "cpu",
            "io",
            "mixed"
          ]
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "slo_kind": {
      "type": "string",
      "enum": [
        "error_rate",
        "latency_p95_ms",
        "availability"
      ]
    },
    "slo_target_error_rate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max"
      ],
      "properties": {
        "max": {
          "$ref": "#/$defs/ratio"
        }
      }
    },
    "slo_target_availability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min"
      ],
      "properties": {
        "min": {
          "$ref": "#/$defs/ratio"
        }
      }
    },
    "slo_target_latency_p95_ms": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_ms"
      ],
      "properties": {
        "max_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "slo_objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective_id",
        "kind",
        "window_s",
        "target"
      ],
      "properties": {
        "objective_id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/slo_kind"
        },
        "window_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31536000
        },
        "target": {}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "error_rate"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "target": {
                "$ref": "#/$defs/slo_target_error_rate"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "availability"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "target": {
                "$ref": "#/$defs/slo_target_availability"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "latency_p95_ms"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "target": {
                "$ref": "#/$defs/slo_target_latency_p95_ms"
              }
            }
          }
        }
      ]
    },
    "slo_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objectives"
      ],
      "properties": {
        "objectives": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/slo_objective"
          }
        }
      }
    },
    "executable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "image"
      ],
      "properties": {
        "kind": {
          "const": "oci_image"
        },
        "image": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "container_port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "binding_probe_hint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_ref",
        "binding_kind"
      ],
      "properties": {
        "binding_ref": {
          "$ref": "#/$defs/id"
        },
        "binding_kind": {
          "type": "string",
          "enum": [
            "postgres",
            "mysql",
            "sqlite",
            "redis",
            "kafka",
            "amqp",
            "s3",
            "secret",
            "otlp"
          ]
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probe_kind"
      ],
      "properties": {
        "probe_kind": {
          "type": "string",
          "enum": [
            "http",
            "exec"
          ]
        },
        "path": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "^/"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "port": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "initial_delay_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "period_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "success_threshold": {
          "type": "integer",
          "minimum": 1
        },
        "failure_threshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startup": {
          "oneOf": [
            {
              "$ref": "#/$defs/probe"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "readiness": {
          "oneOf": [
            {
              "$ref": "#/$defs/probe"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "liveness": {
          "oneOf": [
            {
              "$ref": "#/$defs/probe"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_ref",
        "topic",
        "consumer_group"
      ],
      "properties": {
        "binding_ref": {
          "$ref": "#/$defs/id"
        },
        "topic": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "consumer_group": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "ack_mode": {
          "type": "string",
          "enum": [
            "auto",
            "manual"
          ]
        },
        "max_in_flight": {
          "type": "integer",
          "minimum": 1
        },
        "drain_timeout_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cron"
      ],
      "properties": {
        "cron": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "timezone": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "concurrency_policy": {
          "type": "string",
          "enum": [
            "allow",
            "forbid",
            "replace"
          ]
        },
        "retry_limit": {
          "type": "integer",
          "minimum": 0
        },
        "start_deadline_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "suspend": {
          "type": "boolean"
        }
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "rolling",
            "canary-lite",
            "recreate"
          ]
        },
        "max_unavailable": {
          "type": "string",
          "minLength": 1
        },
        "max_surge": {
          "type": "string",
          "minLength": 1
        },
        "canary_percent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_replicas",
        "max_replicas"
      ],
      "properties": {
        "min_replicas": {
          "type": "integer",
          "minimum": 0
        },
        "max_replicas": {
          "type": "integer",
          "minimum": 1
        },
        "target_cpu_utilization": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "target_inflight": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cell_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell_key",
        "cell_kind",
        "runtime_class",
        "ingress_kind",
        "scale_class",
        "topology_group",
        "binding_refs",
        "binding_probe_hints"
      ],
      "properties": {
        "cell_key": {
          "$ref": "#/$defs/id"
        },
        "cell_kind": {
          "type": "string",
          "enum": [
            "api-cell",
            "event-consumer",
            "scheduled-job",
            "policy-service",
            "workflow-service",
            "mcp-tool"
          ]
        },
        "runtime_class": {
          "type": "string",
          "enum": [
            "wasm-component",
            "native-http",
            "native-worker",
            "embedded-kernel"
          ]
        },
        "ingress_kind": {
          "type": "string",
          "enum": [
            "http",
            "event",
            "schedule",
            "workflow",
            "mcp"
          ]
        },
        "scale_class": {
          "type": "string",
          "enum": [
            "replicated-http",
            "partitioned-consumer",
            "singleton-orchestrator",
            "leased-worker",
            "burst-batch",
            "embedded-kernel"
          ]
        },
        "topology_group": {
          "$ref": "#/$defs/id"
        },
        "binding_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "default": []
        },
        "binding_probe_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binding_probe_hint"
          },
          "default": []
        },
        "execution_kind": {
          "type": "string",
          "enum": [
            "oci_image",
            "embedded"
          ]
        },
        "probes": {
          "$ref": "#/$defs/probes"
        },
        "event": {
          "$ref": "#/$defs/event"
        },
        "schedule": {
          "$ref": "#/$defs/schedule"
        },
        "rollout": {
          "$ref": "#/$defs/rollout"
        },
        "autoscaling": {
          "$ref": "#/$defs/autoscaling"
        },
        "executable": {
          "$ref": "#/$defs/executable"
        }
      }
    }
  }
}
