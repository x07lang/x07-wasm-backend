{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.device.package.report.schema.json",
  "title": "x07.wasm.device.package.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm device package`.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "command", "ok", "exit_code", "diagnostics", "meta", "result"],
  "properties": {
    "schema_version": { "const": "x07.wasm.device.package.report@0.1.0" },
    "command": { "const": "x07-wasm.device.package" },
    "ok": { "type": "boolean" },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic" },
      "default": []
    },
    "meta": { "$ref": "#/$defs/meta" },
    "result": { "$ref": "#/$defs/result" }
  },
  "$defs": {
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "x07-wasm" },
        "version": { "type": "string" },
        "git_sha": { "type": "string", "pattern": "^[0-9a-fA-F]{7,40}$" },
        "rustc": { "type": "string" },
        "clang": { "type": "string" },
        "wasm_ld": { "type": "string" },
        "wasmtime": { "type": "string" }
      }
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes_len"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "bytes_len": { "type": "integer", "minimum": 0 }
      }
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uses_os_time", "uses_network", "uses_process"],
      "properties": {
        "uses_os_time": { "type": "boolean" },
        "uses_network": { "type": "boolean" },
        "uses_process": { "type": "boolean" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "elapsed_ms", "cwd", "argv", "inputs", "outputs", "nondeterminism"],
      "properties": {
        "tool": { "$ref": "#/$defs/tool_meta" },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "cwd": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/file_digest" }, "default": [] },
        "nondeterminism": { "$ref": "#/$defs/nondeterminism" }
      }
    },
    "profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "v"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "v": { "type": "integer", "minimum": 1 }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "type": "string", "enum": ["dir", "archive"] },
        "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "archive" } } },
          "then": { "required": ["sha256"] }
        }
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "target", "bundle_dir", "out_dir", "package_manifest", "package"],
      "properties": {
        "profile": { "$ref": "#/$defs/profile_ref" },
        "target": { "type": "string", "enum": ["desktop", "ios", "android"] },
        "bundle_dir": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "out_dir": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "package_manifest": { "$ref": "#/$defs/file_digest" },
        "package": { "$ref": "#/$defs/package" }
      }
    }
  }
}

