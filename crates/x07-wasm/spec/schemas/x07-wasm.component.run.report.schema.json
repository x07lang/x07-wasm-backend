{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-wasm.component.run.report.schema.json",
  "title": "x07.wasm.component.run.report@0.1.0",
  "description": "Machine-readable report emitted by `x07-wasm component run`.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "x07.wasm.component.run.report@0.1.0"
    },
    "command": {
      "type": "string",
      "const": "x07-wasm.component.run"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "https://x07.io/spec/x07diag.schema.json#/$defs/diagnostic"
      },
      "default": []
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "result": {
      "$ref": "#/$defs/result"
    }
  },
  "required": [
    "schema_version",
    "command",
    "ok",
    "exit_code",
    "diagnostics",
    "meta",
    "result"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "u64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "tool_meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "const": "x07-wasm"
        },
        "version": {
          "type": "string"
        },
        "git_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{7,40}$"
        },
        "rustc": {
          "type": "string"
        },
        "clang": {
          "type": "string"
        },
        "wasm_ld": {
          "type": "string"
        },
        "wasmtime": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ]
    },
    "file_digest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes_len": {
          "$ref": "#/$defs/u64"
        }
      },
      "required": [
        "path",
        "sha256",
        "bytes_len"
      ]
    },
    "nondeterminism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "uses_os_time": {
          "type": "boolean"
        },
        "uses_network": {
          "type": "boolean"
        },
        "uses_process": {
          "type": "boolean"
        }
      },
      "required": [
        "uses_os_time",
        "uses_network",
        "uses_process"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "$ref": "#/$defs/tool_meta"
        },
        "elapsed_ms": {
          "$ref": "#/$defs/u64"
        },
        "cwd": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_digest"
          },
          "default": []
        },
        "nondeterminism": {
          "$ref": "#/$defs/nondeterminism"
        }
      },
      "required": [
        "tool",
        "elapsed_ms",
        "cwd",
        "argv",
        "inputs",
        "outputs",
        "nondeterminism"
      ]
    },
    "blob_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bytes_len"
      ],
      "description": "Reference to a binary blob. Provide either {path,sha256} or {base64}. sha256 is strongly recommended.",
      "properties": {
        "bytes_len": {
          "$ref": "#/$defs/u64"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "base64": {
          "type": "string"
        }
      }
    },
    "run_outcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "ok",
            "err",
            "timeout",
            "trap",
            "engine_failed",
            "component_compile_failed",
            "linker_failed"
          ]
        },
        "max_wall_ms": {
          "$ref": "#/$defs/u64"
        },
        "trap": {
          "type": "string",
          "minLength": 0,
          "maxLength": 16384
        }
      },
      "required": [
        "outcome"
      ]
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "component": {
          "$ref": "#/$defs/file_digest"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 4096
          },
          "default": []
        },
        "stdin": {
          "$ref": "#/$defs/blob_ref"
        },
        "stdout": {
          "$ref": "#/$defs/blob_ref"
        },
        "stderr": {
          "$ref": "#/$defs/blob_ref"
        },
        "run": {
          "$ref": "#/$defs/run_outcome"
        },
        "incident_dir": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 4096
        }
      },
      "required": [
        "component",
        "args",
        "stdin",
        "stdout",
        "stderr",
        "run",
        "incident_dir"
      ]
    }
  }
}
