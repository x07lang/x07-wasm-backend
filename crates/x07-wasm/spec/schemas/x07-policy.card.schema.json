{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/spec/x07-policy.card.schema.json",
  "title": "x07.policy.card@0.1.0",
  "description": "Machine-readable runtime governance policy card (minimal enforceable subset).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "v", "rules"],
  "properties": {
    "schema_version": { "const": "x07.policy.card@0.1.0" },
    "id": { "$ref": "#/$defs/id" },
    "v": { "type": "integer", "minimum": 1 },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "owner": { "type": "string", "minLength": 1, "maxLength": 256 },
        "description": { "type": "string", "maxLength": 16384 }
      },
      "default": {}
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "json_pointer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^/[^\\s]*$"
    },
    "target": {
      "type": "string",
      "enum": ["ops_profile", "capabilities", "slo_profile", "deploy_plan", "app_pack", "provenance_attestation"]
    },
    "effect": {
      "type": "string",
      "enum": ["deny", "warn", "require"]
    },
    "assert_op": {
      "type": "string",
      "enum": ["eq", "neq", "exists", "not_exists", "matches", "in", "nin"]
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "path"],
      "properties": {
        "op": { "$ref": "#/$defs/assert_op" },
        "path": { "$ref": "#/$defs/json_pointer" },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": { "op": { "enum": ["eq", "neq", "matches", "in", "nin"] } },
            "required": ["op"]
          },
          "then": { "required": ["value"] }
        },
        {
          "if": {
            "properties": { "op": { "enum": ["exists", "not_exists"] } },
            "required": ["op"]
          },
          "then": { "not": { "required": ["value"] } }
        }
      ]
    },
    "json_patch_op": {
      "type": "string",
      "enum": ["add", "remove", "replace", "move", "copy", "test"]
    },
    "json_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "path"],
      "properties": {
        "op": { "$ref": "#/$defs/json_patch_op" },
        "path": { "$ref": "#/$defs/json_pointer" },
        "from": { "$ref": "#/$defs/json_pointer" },
        "value": {}
      },
      "allOf": [
        {
          "if": { "properties": { "op": { "enum": ["move", "copy"] } }, "required": ["op"] },
          "then": { "required": ["from"] }
        },
        {
          "if": { "properties": { "op": { "enum": ["add", "replace", "test"] } }, "required": ["op"] },
          "then": { "required": ["value"] }
        }
      ]
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "effect", "assertions", "patches"],
      "properties": {
        "id": { "$ref": "#/$defs/rule_id" },
        "target": { "$ref": "#/$defs/target" },
        "effect": { "$ref": "#/$defs/effect" },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/assertion" }
        },
        "patches": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/json_patch" },
          "default": []
        },
        "reason": { "type": "string", "maxLength": 4096 }
      }
    }
  }
}
